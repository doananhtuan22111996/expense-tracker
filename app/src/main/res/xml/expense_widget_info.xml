<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget provider metadata for ExpenseWidgetReceiver.

  Sizing notes:
  - minWidth/minHeight (110dp × 40dp): the absolute smallest placement, which
    matches a 2×1 cell grid on typical launchers (cell size ≈ 70dp; formula
    70*cells − 30 → 2 cells ≈ 110dp).
  - targetCellWidth/targetCellHeight (2/1): Android 12+ places the widget at
    the "small" size by default. Users can resize up to 4×2 for the medium
    layout; ExpenseWidget's SizeMode.Responsive dispatches internally.
  - resizeMode="horizontal|vertical": allow the launcher to resize both axes
    so users can grow from 2×1 → 4×2.
  - updatePeriodMillis="0": we do NOT want the framework's built-in refresh
    (rate-limited to 30 min and can drain battery). Task 1.7 wires
    repository-hook refresh (updateAll on data change) and Task 1.8 adds a
    30-minute WorkManager top-up. 0 = disable framework auto-refresh.

  Preview strategy:
  - previewLayout (Android 12+): the launcher picker instantiates
    widget_preview.xml — a static LinearLayout mock of the medium layout —
    so users see what the widget actually looks like before placing it.
  - previewImage (Android 8–11): vector drawable fallback for older launchers
    that don't honor previewLayout. Shows a rounded surface tile; not as
    informative but at least doesn't reuse the app icon.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/widget_description"
    android:initialLayout="@layout/widget_loading"
    android:minWidth="110dp"
    android:minHeight="40dp"
    android:minResizeWidth="110dp"
    android:minResizeHeight="40dp"
    android:previewImage="@drawable/widget_preview_bg"
    android:previewLayout="@layout/widget_preview"
    android:resizeMode="horizontal|vertical"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:updatePeriodMillis="0"
    android:widgetCategory="home_screen" />
