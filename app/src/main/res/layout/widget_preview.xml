<?xml version="1.0" encoding="utf-8"?>
<!--
  Static preview shown by Android 12+ in the launcher's Widgets picker. The
  launcher instantiates this layout once to give users a sense of what the
  widget will look like before placing it — no data binding is performed, so
  every value here is a frozen placeholder.

  Mirrors the medium (4×2) Glance layout in widget/ui/ExpenseWidgetContent.kt
  so the preview matches what the user actually gets after placement. If the
  Glance layout changes meaningfully, update this file to match — there is no
  automatic sync.

  Colors are hard-coded Material 3 light-surface tones rather than theme
  references because the launcher picker runs outside the app's theme context.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_preview_bg"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp">

    <!-- Today row: label + amount + "+" button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_today"
                android:textColor="#666666"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_preview_today_amount"
                android:textColor="#1C1B1F"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/widget_preview_add_button"
            android:gravity="center"
            android:text="@string/widget_preview_add_button"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="8dp" />

    <!-- This month row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="bottom"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_this_month"
            android:textColor="#666666"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_preview_month_amount"
            android:textColor="#1C1B1F"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="10dp" />

    <!-- Budget progress row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_preview_budget_progress"
            android:textColor="#666666"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_preview_budget_percent"
            android:textColor="#6750A4"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Progress bar: background is widget_preview_progress_track — a gradient
         shape with a hard color stop at ~45% that reads visually as a filled
         bar. A live ProgressBar would inherit the launcher's theme and look
         inconsistent across OEMs, so we hand-roll the visual instead. -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/widget_preview_progress_track" />
</LinearLayout>
