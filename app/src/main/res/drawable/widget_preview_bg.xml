<?xml version="1.0" encoding="utf-8"?>
<!--
    Background for the widget preview image shown in the launcher picker on
    Android 8–11 (where `android:previewLayout` isn't supported). Android 12+
    renders `@layout/widget_preview` directly.

    Color is a static Material 3 light-surface (#F5F5F5) rather than a theme
    reference — the launcher picker doesn't have app theme context.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="16dp" />
    <solid android:color="#F5F5F5" />
    <stroke
        android:width="1dp"
        android:color="#E0E0E0" />
</shape>
